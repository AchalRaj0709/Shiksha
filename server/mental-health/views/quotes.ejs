<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
    <%- include('partials/navbar', { page }) %>

        <main class="main-content">
            <div class="container">
                <div class="page-header">
                    <h1 class="page-title">Motivational Resources</h1>
                    <p class="page-subtitle">Find inspiration and encouragement for your journey.</p>
                </div>

                <div class="quotes-container">
                    <!-- Quote Display -->
                    <div class="quote-display">
                        <div class="quote-icon">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z" />
                            </svg>
                        </div>
                        <blockquote class="quote-text" id="quoteText">
                            <%= quote.text %>
                        </blockquote>
                        <p class="quote-author" id="quoteAuthor">— <%= quote.author %>
                        </p>
                    </div>

                    <button class="btn btn-primary refresh-quote" id="refreshQuote">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path
                                d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" />
                        </svg>
                        Get New Quote
                    </button>

                    <!-- Quote Categories -->
                    <div class="quote-categories">
                        <h3>Quote Themes</h3>
                        <div class="categories-grid">
                            <span class="category-badge">Success</span>
                            <span class="category-badge">Perseverance</span>
                            <span class="category-badge">Learning</span>
                            <span class="category-badge">Growth</span>
                            <span class="category-badge">Courage</span>
                            <span class="category-badge">Wisdom</span>
                        </div>
                    </div>

                    <!-- Daily Affirmations -->
                    <div class="affirmations-section">
                        <h3>Daily Affirmations</h3>
                        <div class="affirmations-grid">
                            <div class="affirmation-card">
                                <div class="affirmation-icon">💪</div>
                                <p>I am capable of achieving my goals</p>
                            </div>
                            <div class="affirmation-card">
                                <div class="affirmation-icon">🌟</div>
                                <p>I believe in my abilities</p>
                            </div>
                            <div class="affirmation-card">
                                <div class="affirmation-icon">🎯</div>
                                <p>I am focused and determined</p>
                            </div>
                            <div class="affirmation-card">
                                <div class="affirmation-icon">🚀</div>
                                <p>Every day I'm getting better</p>
                            </div>
                            <div class="affirmation-card">
                                <div class="affirmation-icon">💡</div>
                                <p>I embrace challenges as opportunities</p>
                            </div>
                            <div class="affirmation-card">
                                <div class="affirmation-icon">🌈</div>
                                <p>I am worthy of success</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>

            <script src="/js/main.js"></script>
            <script src="/js/quotes.js"></script>
</body>

</html>