<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
    <%- include('partials/navbar', { page }) %>

        <main class="main-content">
            <div class="container">
                <div class="page-header">
                    <h1 class="page-title">Guided Meditation</h1>
                    <p class="page-subtitle">Choose a meditation session that fits your schedule and needs.</p>
                </div>

                <div class="meditation-container">
                    <!-- Active Player -->
                    <div class="meditation-player" id="meditationPlayer" style="display: none;">
                        <div class="player-header">
                            <h3 id="playerTitle">Meditation Session</h3>
                            <button class="close-player" id="closePlayer">✕</button>
                        </div>
                        <div class="player-body">
                            <div class="audio-visualizer">
                                <div class="visualizer-bar"></div>
                                <div class="visualizer-bar"></div>
                                <div class="visualizer-bar"></div>
                                <div class="visualizer-bar"></div>
                                <div class="visualizer-bar"></div>
                            </div>
                            <audio id="audioPlayer" preload="metadata">
                                <source src="" type="audio/mpeg">
                                Your browser does not support the audio element.
                            </audio>
                            <div class="progress-container">
                                <div class="progress-bar" id="progressBar"></div>
                                <div class="progress-time">
                                    <span id="currentTime">0:00</span>
                                    <span id="totalTime">0:00</span>
                                </div>
                            </div>
                            <div class="player-controls">
                                <button class="control-btn" id="playPauseBtn">
                                    <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M8 5v14l11-7z" />
                                    </svg>
                                    <svg class="pause-icon" viewBox="0 0 24 24" fill="currentColor"
                                        style="display: none;">
                                        <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Session List -->
                    <div class="meditation-grid">
                        <% meditations.forEach(function(meditation) { %>
                            <div class="meditation-card" data-id="<%= meditation.id %>"
                                data-title="<%= meditation.title %>" data-audio="<%= meditation.audioUrl %>">
                                <div class="meditation-header">
                                    <div class="meditation-category">
                                        <%= meditation.category %>
                                    </div>
                                    <div class="meditation-duration">
                                        <%= meditation.duration %> min
                                    </div>
                                </div>
                                <h3 class="meditation-title">
                                    <%= meditation.title %>
                                </h3>
                                <p class="meditation-description">
                                    <%= meditation.description %>
                                </p>
                                <div class="meditation-benefits">
                                    <% meditation.benefits.forEach(function(benefit) { %>
                                        <span class="benefit-tag">
                                            <%= benefit %>
                                        </span>
                                        <% }); %>
                                </div>
                                <button class="btn btn-primary play-meditation">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M8 5v14l11-7z" />
                                    </svg>
                                    Play Session
                                </button>
                            </div>
                            <% }); %>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>

            <script src="/js/main.js"></script>
            <script src="/js/meditation.js"></script>
</body>

</html>